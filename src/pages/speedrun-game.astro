---
import Base from '../layouts/Base.astro';

const SITE = 'https://www.indiespeedrun.com';

const breadcrumbs = [
  { name: 'Home', url: SITE + '/' },
  { name: 'Speedrun Game', url: SITE + '/speedrun-game/' },
];

const videoGameSchema = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'IndieSpeedRun Platformer',
  description:
    'A free browser-based speedrun platformer: 8 levels, in-game millisecond timer, and local best-times tracking. Original IP — no third-party dependencies.',
  url: `${SITE}/speedrun-game/`,
  genre: ['Platformer', 'Speedrun'],
  gamePlatform: 'Web Browser',
  applicationCategory: 'Game',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  isAccessibleForFree: true,
  author: {
    '@type': 'Organization',
    name: 'IndieSpeedRun',
    url: SITE,
  },
};
---

<Base
  title="Free Browser Speedrun Platformer — 8 Levels, In-Game Timer"
  description="Play a free original speedrun platformer in your browser. 8 levels, in-game ms timer, local best-times board, keyboard + touch controls. No install, no account."
  canonicalPath="/speedrun-game/"
  breadcrumbs={breadcrumbs}
  jsonLd={videoGameSchema}
>
  <div class="max-w-4xl mx-auto px-4 py-8">

    <nav class="text-sm text-gray-400 mb-8 flex gap-2">
      <a href="/" class="hover:text-gray-300">Home</a>
      <span>/</span>
      <span class="text-gray-300">Speedrun Game</span>
    </nav>

    <h1 class="text-3xl font-bold text-white mb-1">Free Browser Speedrun Platformer</h1>
    <p class="text-gray-400 mb-6 text-sm">8 levels · in-game timer · local best times · no install</p>

    <!-- ========================================================= -->
    <!--  GAME SECTION                                              -->
    <!-- ========================================================= -->
    <div class="mb-14">

      <!-- Canvas wrapper — fixed aspect, responsive width -->
      <div
        id="canvas-wrapper"
        class="relative w-full bg-gray-950 rounded-xl overflow-hidden border border-gray-800"
        style="aspect-ratio: 16/9; max-height: 450px;"
      >
        <!-- Canvas (always in DOM for correct sizing) -->
        <canvas
          id="game-canvas"
          width="800"
          height="450"
          class="w-full h-full block"
          aria-label="IndieSpeedRun platformer game"
        ></canvas>

        <!-- Play overlay — covers canvas until user clicks Play -->
        <div
          id="play-overlay"
          class="absolute inset-0 flex flex-col items-center justify-center bg-gray-950 cursor-pointer"
          role="button"
          tabindex="0"
        >
          <div class="w-20 h-20 rounded-full bg-indigo-600 hover:bg-indigo-500 flex items-center justify-center mb-4 transition-colors shadow-lg shadow-indigo-900/50">
            <span class="text-white text-4xl leading-none pl-1" aria-hidden="true">▶</span>
          </div>
          <p class="text-white font-bold text-xl mb-1">Play</p>
          <p class="text-gray-400 text-sm">8 levels — how fast can you finish?</p>
          <p class="text-gray-400 text-xs mt-3">Arrow keys / WASD + jump on Up/W/Space</p>
        </div>
      </div>

      <!-- Touch controls — shown only on touch devices via JS -->
      <div
        id="touch-controls"
        class="hidden mt-3 select-none"
        aria-label="Touch controls"
      >
        <div class="flex justify-between items-center gap-3">
          <div class="flex gap-3">
            <button
              id="touch-left"
              class="w-16 h-16 rounded-xl bg-gray-800 border border-gray-700 text-white text-2xl flex items-center justify-center active:bg-gray-700 touch-none"
              aria-label="Move left"
            >◀</button>
            <button
              id="touch-right"
              class="w-16 h-16 rounded-xl bg-gray-800 border border-gray-700 text-white text-2xl flex items-center justify-center active:bg-gray-700 touch-none"
              aria-label="Move right"
            >▶</button>
          </div>
          <button
            id="touch-jump"
            class="w-24 h-16 rounded-xl bg-indigo-700 border border-indigo-600 text-white font-bold text-lg flex items-center justify-center active:bg-indigo-600 touch-none"
            aria-label="Jump"
          >Jump</button>
        </div>
        <button
          id="touch-replay"
          class="hidden mt-2 w-full py-2 rounded-lg bg-gray-800 text-gray-300 text-sm border border-gray-700"
          aria-label="Play again"
        >Play again</button>
      </div>

      <!-- Leaderboard — your local best times -->
      <div class="mt-6 bg-gray-900 border border-gray-800 rounded-xl p-5">
        <h2 class="text-base font-semibold text-white mb-1">Your best times</h2>
        <p class="text-xs text-gray-400 mb-4">
          Stored locally in your browser — personal records only, not a global leaderboard.
        </p>
        <table class="w-full text-left border-collapse" aria-label="Your local best times">
          <thead>
            <tr class="border-b border-gray-700">
              <th scope="col" class="pb-2 pr-4 text-xs text-gray-400 font-medium">#</th>
              <th scope="col" class="pb-2 pr-4 text-xs text-gray-400 font-medium font-mono">Time</th>
              <th scope="col" class="pb-2 text-xs text-gray-400 font-medium">Date</th>
            </tr>
          </thead>
          <tbody id="leaderboard-rows">
            <tr>
              <td colspan="3" class="py-2 text-gray-400 text-sm">No runs yet — play to set a time.</td>
            </tr>
          </tbody>
        </table>
        <p class="text-xs text-gray-400 mt-3">
          Clearing your browser's site data will erase these times.
        </p>
      </div>
    </div>
    <!-- END GAME SECTION -->

    <!-- ========================================================= -->
    <!--  PAGE COPY                                                  -->
    <!-- ========================================================= -->
    <div class="space-y-12 text-gray-300">

      <section aria-labelledby="how-to-play">
        <h2 id="how-to-play" class="text-2xl font-bold text-white mb-4">How to play</h2>
        <p class="mb-4">Click <strong class="text-gray-100">▶ Play</strong> to load the game. Your goal: reach the <span class="text-yellow-400 font-semibold">▶ yellow flag</span> at the end of each level. The timer starts the moment the first level begins and runs uninterrupted through all 8 levels — this is a full-run speedrun timer, not per-level.</p>
        <div class="overflow-x-auto">
          <table class="text-sm border-collapse w-full max-w-sm">
            <thead>
              <tr class="border-b border-gray-700">
                <th scope="col" class="py-2 pr-8 text-left text-gray-400 font-medium">Key</th>
                <th scope="col" class="py-2 text-left text-gray-400 font-medium">Action</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-800"><td class="py-2 pr-8"><kbd class="bg-gray-800 text-gray-200 px-1.5 py-0.5 rounded font-mono text-xs">← / A</kbd></td><td class="py-2">Move left</td></tr>
              <tr class="border-b border-gray-800"><td class="py-2 pr-8"><kbd class="bg-gray-800 text-gray-200 px-1.5 py-0.5 rounded font-mono text-xs">→ / D</kbd></td><td class="py-2">Move right</td></tr>
              <tr class="border-b border-gray-800"><td class="py-2 pr-8"><kbd class="bg-gray-800 text-gray-200 px-1.5 py-0.5 rounded font-mono text-xs">↑ / W / Space</kbd></td><td class="py-2">Jump</td></tr>
              <tr class="border-b border-gray-800"><td class="py-2 pr-8"><kbd class="bg-gray-800 text-gray-200 px-1.5 py-0.5 rounded font-mono text-xs">Enter / R</kbd></td><td class="py-2">Play again (on win screen)</td></tr>
            </tbody>
          </table>
        </div>
        <p class="text-sm text-gray-400 mt-3">
          On mobile, on-screen Left / Right / Jump buttons appear automatically. All 8 levels are playable on touch — tap and hold Left/Right to move continuously, tap Jump to jump.
        </p>
      </section>

      <section aria-labelledby="levels">
        <h2 id="levels" class="text-2xl font-bold text-white mb-4">The 8 levels</h2>
        <p class="mb-4">Each level introduces a new mechanic and has an optimal line for speedrunners:</p>
        <ol class="space-y-2 list-decimal list-inside text-sm">
          <li><strong class="text-gray-100">First Steps</strong> — two small gaps. Bunny-hop both without stopping.</li>
          <li><strong class="text-gray-100">Step Up</strong> — ascending platforms. Long-jump from the first step to skip two.</li>
          <li><strong class="text-gray-100">The Pit</strong> — wide gap with spikes below. Full-speed run-off lands on the bridge one-shot.</li>
          <li><strong class="text-gray-100">Low Ceiling</strong> — precise landings on narrow platforms above spike clusters.</li>
          <li><strong class="text-gray-100">Spike Alley</strong> — ground run interrupted by spike clusters. Find the jump rhythm.</li>
          <li><strong class="text-gray-100">Two Roads</strong> — high safe route vs low risky route. Low road is shorter.</li>
          <li><strong class="text-gray-100">Precision</strong> — narrow platforms, large gaps. Zero-margin optimal line.</li>
          <li><strong class="text-gray-100">The Final Run</strong> — all mechanics combined. Full-run muscle-memory test.</li>
        </ol>
        <p class="mt-4 text-sm">
          Death restarts the current level but the overall timer keeps running. The goal is to minimise total time across all 8 levels — the same model as a full-game speedrun on <a href="https://www.speedrun.com" target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">speedrun.com</a>.
        </p>
      </section>

      <section aria-labelledby="what-is-speedrun-game">
        <h2 id="what-is-speedrun-game" class="text-2xl font-bold text-white mb-4">What is a browser speedrun game?</h2>
        <p class="mb-3">A browser speedrun game is a game designed from the start to be time-attacked — levels are short, mechanics are learnable, and the game rewards repetition and route knowledge. Unlike casual games, difficulty comes from optimising movement rather than from puzzle obscurity.</p>
        <p>This platformer follows the same design principles as classic speedrun staples: tight controls, consistent physics, and levels that have a "safe" line and a "fast" line. The in-game timer shows the same format (<span class="font-mono text-gray-200">M:SS.mmm</span>) used by speedrun.com leaderboards, so times are directly comparable if you're recording for a community board.</p>
      </section>

      <section aria-labelledby="speedrun-timer-link">
        <h2 id="speedrun-timer-link" class="text-2xl font-bold text-white mb-4">Timing longer runs</h2>
        <p>
          This game's timer covers the full 8-level run. If you're timing a different game — or want split-by-split PB comparison across your own speedruns — use the
          <a href="/speedrun-timer/" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">free speedrun timer</a>
          on this site. It's a separate browser tool with named splits, PB delta tracking, keyboard hotkeys, and copy-to-clipboard export. No connection between the two tools — the timer works for any game.
        </p>
      </section>

      <section aria-labelledby="original-ip">
        <h2 id="original-ip" class="text-2xl font-bold text-white mb-4">Original IP</h2>
        <p class="mb-3">This game is original software built for this site — no third-party engine, no licensed assets. The code is vanilla JavaScript running on an HTML canvas element. All levels, physics, and art are produced here.</p>
        <p>Because it's entirely original, it transfers fully with any sale of this domain and its content — there's no licence to renegotiate and no dependency that can be revoked. The source is in the site's GitHub repository.</p>
      </section>

    </div>
  </div>
</Base>

<script>
// ── Play overlay: lazy-load game JS on click ──────────────────
const overlay  = document.getElementById('play-overlay')!;
const canvas   = document.getElementById('game-canvas') as HTMLCanvasElement;
const touchCtl = document.getElementById('touch-controls')!;
let   gameLoaded = false;

// Show touch controls on touch-capable devices
if ('ontouchstart' in window || navigator.maxTouchPoints > 0) {
  touchCtl.classList.remove('hidden');
}

async function startGame() {
  if (gameLoaded) return;
  gameLoaded = true;
  overlay.style.display = 'none';

  // Dynamic import — game bundle fetched only now (keeps LCP fast)
  const { initGame, updateLeaderboardDOM } = await import('../scripts/speedrun-game');
  updateLeaderboardDOM();
  initGame(canvas);
}

overlay.addEventListener('click', startGame);
overlay.addEventListener('keydown', e => {
  if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); startGame(); }
});

// Populate leaderboard on page load (no game needed for reading localStorage)
(async () => {
  const { updateLeaderboardDOM } = await import('../scripts/speedrun-game');
  updateLeaderboardDOM();
})();
</script>
