---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page Not Found — IndieSpeedRun"
  description="The page you're looking for doesn't exist."
  canonicalPath="/404/"
>
  <div class="max-w-4xl mx-auto px-4 py-32 text-center">
    <p class="text-6xl font-bold text-indigo-500 mb-4">404</p>
    <h1 class="text-2xl font-bold text-white mb-4">Page not found</h1>
    <p class="text-gray-400 mb-8">
      The URL might be from the old site. Legacy paths under <code class="text-indigo-400">/devsite/</code>,
      <code class="text-indigo-400">/teams/</code>, and <code class="text-indigo-400">/teampage/</code>
      redirect to the <a href="/jam-archive/" class="text-indigo-400 hover:text-indigo-300 underline">Jam Archive</a>.
    </p>
    <a href="/" class="inline-block bg-indigo-600 hover:bg-indigo-500 text-white px-6 py-3 rounded-lg transition-colors">
      Back to home
    </a>
  </div>
</Base>
