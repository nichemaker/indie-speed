---
import { getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

const SITE = 'https://www.indiespeedrun.com';

const record = await getEntry('speedrun-records', 'silksong-speedrun');
if (!record) throw new Error('speedrun-records/silksong-speedrun not found');
const { headline, records, videoId, updatedAt, as_of } = record.data;
const verifiedRecords = records.filter((r) => r.verified);

const breadcrumbs = [
  { name: 'Home', url: SITE + '/' },
  { name: 'Speedruns', url: SITE + '/speedruns/' },
  { name: 'Silksong Speedrun', url: SITE + '/speedruns/silksong-speedrun/' },
];

const faqQA = [
  {
    q: 'Is there a Silksong speedrun world record yet?',
    a: 'Yes. Hollow Knight: Silksong has an active speedrunning community on speedrun.com/silksong as of June 2026. The game released in September 2025 and runners were competing across multiple categories within weeks of launch. The Any% leaderboard alone has nearly 1,000 submitted runs.',
  },
  {
    q: 'How long does Silksong take to beat?',
    a: 'The in-game "Speedrunner" achievement requires completing Silksong in under 5 hours — a rough benchmark for efficient play without full speedrunning technique. Optimised speedrun times are far lower: the Any% world record sits at approximately 8 and a half minutes, True Ending at around 2 hours 13 minutes, and 100% at around 3 hours 50 minutes at elite level. A first-time casual playthrough is expected to take considerably longer than the 5-hour achievement window.',
  },
  {
    q: 'How much faster is a Silksong speedrun than a casual playthrough?',
    a: 'It depends on the category. Any% (roughly 8 minutes at elite level) compresses the game into a single sitting, largely by exploiting movement tech. Longer categories like 100% (under 4 hours at WR) are still significantly shorter than a thorough first playthrough. The 5-hour "Speedrunner" achievement sits in between — achievable by focused casual players, not just dedicated speedrunners.',
  },
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Hollow Knight: Silksong Speedruns — Categories, Routes & Records',
  description: 'Hollow Knight: Silksong speedrun world records by category — Any%, Act 1, True Ending, 100%, All Bosses, Low%. Live data from speedrun.com, last verified June 2026.',
  url: `${SITE}/speedruns/silksong-speedrun/`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${SITE}/speedruns/silksong-speedrun/` },
  datePublished: '2026-06-22',
  dateModified: updatedAt,
  author: { '@type': 'Organization', name: 'IndieSpeedRun', url: SITE },
  publisher: { '@type': 'Organization', name: 'IndieSpeedRun', url: SITE },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqQA.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};
---

<Base
  title="Hollow Knight: Silksong Speedruns — Categories, WR & Routes | IndieSpeedRun"
  description="Hollow Knight: Silksong speedrun world records by category — Any%, Act 1, True Ending, 100%, All Bosses, Low%. Live data from speedrun.com, last verified June 2026."
  canonicalPath="/speedruns/silksong-speedrun/"
  ogType="article"
  breadcrumbs={breadcrumbs}
  jsonLd={[articleSchema, faqSchema]}
>
  <div class="max-w-4xl mx-auto px-4 py-8">

    <nav class="text-sm text-gray-400 mb-8 flex gap-2 flex-wrap">
      <a href="/" class="hover:text-gray-300">Home</a>
      <span>/</span>
      <a href="/speedruns/" class="hover:text-gray-300">Speedruns</a>
      <span>/</span>
      <span class="text-gray-300">Silksong Speedrun</span>
    </nav>

    <!-- ============================================================ -->
    <!-- HERO: Headline record + Updated stamp                         -->
    <!-- ============================================================ -->
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-white mb-2">Hollow Knight: Silksong Speedruns — Categories, Routes &amp; Records</h1>

      <div class="flex items-center gap-3 mb-6 flex-wrap">
        <span class="text-xs font-semibold text-gray-400 bg-gray-800 border border-gray-700 rounded-full px-3 py-1">
          Last verified {new Date(updatedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
        <span class="text-xs text-gray-400">Source: <a href="https://www.speedrun.com/silksong" target="_blank" rel="noopener" class="underline underline-offset-2 hover:text-gray-300">speedrun.com/silksong</a></span>
      </div>

      <!-- Any% headline stat block -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <div class="text-xs font-semibold text-indigo-400 uppercase tracking-wider mb-3">{headline.category} — current legitimate top time</div>

        {headline.verified ? (
          <div>
            <div class="flex flex-wrap gap-6 items-start mb-4">
              <div>
                <div class="text-xs text-gray-400 mb-1">LRT <span class="text-gray-400 font-normal">(load-removed, ranked)</span></div>
                <div class="text-3xl font-bold font-mono text-white">{headline.time}</div>
              </div>
              <div>
                <div class="text-xs text-gray-400 mb-1">Runner</div>
                <div class="text-xl font-semibold text-white">{headline.runner}</div>
              </div>
              <div>
                <div class="text-xs text-gray-400 mb-1">Set</div>
                <div class="text-gray-300">{new Date(headline.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
              </div>
            </div>
            <div class="flex items-start gap-3 bg-amber-950/40 border border-amber-800/50 rounded-lg px-4 py-3">
              <span class="text-amber-400 text-sm font-bold shrink-0 mt-0.5">⚠</span>
              <p class="text-amber-300/80 text-xs leading-relaxed">
                <strong class="text-amber-300">Exploit-volatile.</strong> A recent movement exploit cut Any% times from the ~59–63 min pre-exploit era to under 9 minutes. The leaderboard #1 position is an invalid placeholder (0.001s); this is the current legitimate top time.
                {' '}<strong class="text-amber-300">Verify the live WR at <a href="https://www.speedrun.com/silksong" target="_blank" rel="noopener" class="underline hover:text-amber-200">speedrun.com/silksong</a></strong> — this sub-category updates frequently.
              </p>
            </div>
          </div>
        ) : (
          <div class="flex items-center gap-2 bg-amber-950/40 border border-amber-800/50 rounded-lg px-4 py-3">
            <span class="text-amber-400 text-sm font-semibold">⚠ No verified headline record yet</span>
            <span class="text-amber-400 text-xs">— check speedrun.com/silksong</span>
          </div>
        )}
      </div>
    </div>

    <!-- ============================================================ -->
    <!-- BODY COPY                                                      -->
    <!-- ============================================================ -->
    <div class="space-y-14 text-gray-300">

      <!-- Is there a WR yet? -->
      <section aria-labelledby="wr-exists">
        <h2 id="wr-exists" class="text-2xl font-bold text-white mb-4">Is there a Silksong speedrun world record yet?</h2>
        <p class="mb-4">
          Yes. <a href="https://www.speedrun.com/silksong" target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">speedrun.com/silksong</a> is the official authority, and the community has been active since the game released in September 2025. As of our last verification (June 2026), six categories have active leaderboards with verified submissions.
        </p>
        <p>
          The Any% leaderboard has nearly 1,000 submitted runs — unusually high volume for a game less than a year old. The records table below lists the verified WR for each category, sourced from speedrun.com on {new Date(as_of).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}.
        </p>
      </section>

      <!-- The Speedrunner achievement -->
      <section aria-labelledby="speedrunner-achievement">
        <h2 id="speedrunner-achievement" class="text-2xl font-bold text-white mb-5">The "Speedrunner" achievement</h2>

        <h3 class="text-lg font-semibold text-white mb-3">What the 5-hour Speedrunner achievement is</h3>
        <p class="mb-4">
          Hollow Knight: Silksong includes an in-game achievement for completing the game in under 5 hours. This is separate from the speedrun.com leaderboard: it is a personal milestone tracked by the game itself, not a community record. Earning it does not require speedrunning knowledge — it rewards efficient, focused play by someone who knows where they are going.
        </p>
        <p class="mb-8">
          The 5-hour window is generous enough that a second or third playthrough, played with intent, should be reachable for most players without frame-perfect execution or exploit knowledge.
        </p>

        <h3 class="text-lg font-semibold text-white mb-3">How people approach the 5-hour run</h3>
        <p class="mb-4">
          The community has documented efficient approaches that don't require precise speedrunning technique. The broad principles are consistent: minimise backtracking, pursue main objectives in an efficient order, and skip optional content that doesn't contribute to the completion condition.
        </p>
        <p>
          For a maintained route, check Steam community guides for Silksong or <a href="https://www.reddit.com/r/SilksongSpeedrun/" target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">r/SilksongSpeedrun</a> — community guides are updated as efficient pathing is refined. We don't publish a specific route here because route consensus evolves faster than our verification cadence, and an outdated route is worse than a pointer to a live resource.
        </p>
      </section>

      <!-- Categories explained -->
      <section aria-labelledby="categories">
        <h2 id="categories" class="text-2xl font-bold text-white mb-4">Silksong speedrun categories explained</h2>
        <p class="mb-6 text-gray-400 text-sm">Six categories are actively tracked on speedrun.com/silksong as of June 2026.</p>

        <div class="space-y-5">
          <div class="border-l-2 border-indigo-600 pl-4">
            <h3 class="font-semibold text-white mb-1">Any%</h3>
            <p class="text-sm text-gray-400">
              Reach the credits as fast as possible by any means available. Currently dominated by a movement exploit that cut times from the ~59–63 minute era to under 9 minutes. The category is active and volatile. Note: the leaderboard #1 position is an invalid 0.001s placeholder; pyuk's 8:33.22 (set 2026-06-20) is the current legitimate top time. Verify live at speedrun.com/silksong.
            </p>
          </div>
          <div class="border-l-2 border-gray-700 pl-4">
            <h3 class="font-semibold text-white mb-1">Act 1</h3>
            <p class="text-sm text-gray-400">
              Complete Act 1 of the game as fast as possible. Covers the first major chapter only, making it the most accessible entry point for new Silksong runners — runs are short enough for rapid practice cycles. 289 runs on the leaderboard as of June 2026.
            </p>
          </div>
          <div class="border-l-2 border-gray-700 pl-4">
            <h3 class="font-semibold text-white mb-1">All Bosses</h3>
            <p class="text-sm text-gray-400">
              Defeat every boss in the game before credits. Requires planning an efficient boss order across the full game, then executing across sustained fights with no safety net. 29 runs as of June 2026.
            </p>
          </div>
          <div class="border-l-2 border-gray-700 pl-4">
            <h3 class="font-semibold text-white mb-1">True Ending</h3>
            <p class="text-sm text-gray-400">
              Achieve the game's true ending, which requires completing additional objectives beyond the standard credits roll. At 2:13:05 world record, this is a multi-hour category testing sustained execution and deep game knowledge.
            </p>
          </div>
          <div class="border-l-2 border-gray-700 pl-4">
            <h3 class="font-semibold text-white mb-1">100%</h3>
            <p class="text-sm text-gray-400">
              Full completion — all items, collectibles, and objectives. World record: 3:49:59. The longest category currently on the board, with 41 submitted runs.
            </p>
          </div>
          <div class="border-l-2 border-gray-700 pl-4">
            <h3 class="font-semibold text-white mb-1">Low%</h3>
            <p class="text-sm text-gray-400">
              Complete the game collecting as few items as possible. Like most Metroidvanias, the exact definition of "minimum" is an ongoing community debate — what counts as a mandatory pick-up versus a skippable one is part of the ruleset discussion. See the current category rules at speedrun.com/silksong for the authoritative definition. 21 runs; run video is hosted on Bilibili rather than YouTube.
            </p>
          </div>
        </div>
      </section>

      <!-- ============================================================ -->
      <!-- RECORDS TABLE                                                 -->
      <!-- ============================================================ -->
      <section aria-labelledby="records-table">
        <h2 id="records-table" class="text-2xl font-bold text-white mb-2">Silksong world records by category</h2>
        <p class="text-gray-400 text-sm mb-4">
          Verified against <a href="https://www.speedrun.com/silksong" target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">speedrun.com/silksong</a> as of {new Date(as_of).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}.
          Only verified rows appear here. LRT = realtime with loads removed (the ranked timing method).
        </p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse" aria-label="Hollow Knight: Silksong speedrun world records by category">
            <thead>
              <tr class="border-b border-gray-700">
                <th scope="col" class="pb-3 pr-4 text-left text-xs text-gray-400 font-semibold">Category</th>
                <th scope="col" class="pb-3 pr-4 text-left text-xs text-gray-400 font-mono font-semibold">LRT <span class="font-sans font-normal">(ranked)</span></th>
                <th scope="col" class="pb-3 pr-4 text-left text-xs text-gray-400 font-semibold">Runner</th>
                <th scope="col" class="pb-3 pr-4 text-left text-xs text-gray-400 font-semibold">Date set</th>
                <th scope="col" class="pb-3 pr-4 text-left text-xs text-gray-400 font-semibold">Video</th>
                <th scope="col" class="pb-3 text-left text-xs text-gray-400 font-semibold">Leaderboard</th>
              </tr>
            </thead>
            <tbody>
              {verifiedRecords.map((r) => (
                <tr class={`border-b border-gray-800${r.caveat ? ' bg-amber-950/10' : ''}`}>
                  <td class="py-3 pr-4 text-gray-200 font-medium">
                    {r.category}
                    {r.caveat && (
                      <span class="text-amber-400 ml-1 text-xs" title={r.caveat}>⚠</span>
                    )}
                  </td>
                  <td class="py-3 pr-4 font-mono font-semibold text-white">{r.time}</td>
                  <td class="py-3 pr-4 text-gray-200">{r.runner}</td>
                  <td class="py-3 pr-4 text-gray-300 text-xs">{r.date}</td>
                  <td class="py-3 pr-4">
                    {r.videoUrl ? (
                      <a href={r.videoUrl} target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300 text-xs">
                        {r.videoUrl.includes('bilibili') ? 'Watch (Bilibili) ↗' : 'Watch ↗'}
                      </a>
                    ) : <span class="text-gray-600">—</span>}
                  </td>
                  <td class="py-3">
                    <a href={r.sourceUrl} target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300 text-xs">speedrun.com ↗</a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {verifiedRecords.some((r) => r.caveat) && (
          <p class="text-xs text-amber-400/80 mt-3">⚠ Any% is exploit-volatile — verify the current WR live at speedrun.com/silksong before citing this figure.</p>
        )}
        <p class="text-xs text-gray-400 mt-3">
          Editorial standards: how we verify figures — <a href="/methodology/" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">our methodology</a>.
        </p>
      </section>

      <!-- How long to beat -->
      <section aria-labelledby="how-long">
        <h2 id="how-long" class="text-2xl font-bold text-white mb-4">How long does Silksong take to beat (casual vs speedrun)?</h2>
        <p class="mb-4">
          The in-game "Speedrunner" achievement targets under 5 hours — a useful casual benchmark. Elite speedrun times are considerably shorter:
        </p>
        <ul class="list-disc pl-6 space-y-1 text-sm text-gray-400 mb-4">
          <li><strong class="text-gray-200">Any%</strong> — approximately 8 minutes 33 seconds at world-record level (exploit-heavy; verify live at speedrun.com/silksong).</li>
          <li><strong class="text-gray-200">Act 1 only</strong> — approximately 9 minutes 3 seconds at world record.</li>
          <li><strong class="text-gray-200">True Ending</strong> — approximately 2 hours 13 minutes.</li>
          <li><strong class="text-gray-200">100%</strong> — approximately 3 hours 50 minutes.</li>
        </ul>
        <p>
          A first-time casual playthrough will take considerably longer than the 5-hour achievement cap. For current community estimates, <a href="https://www.reddit.com/r/SilksongSpeedrun/" target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">r/SilksongSpeedrun</a> is the best source — real player data from the community reflects where the casual ceiling actually sits.
        </p>
      </section>

      <!-- Where runs are tracked -->
      <section aria-labelledby="tracking">
        <h2 id="tracking" class="text-2xl font-bold text-white mb-4">Where Silksong speedruns are tracked</h2>
        <p class="mb-4">
          <a href="https://www.speedrun.com/silksong" target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">speedrun.com/silksong</a> is the main leaderboard authority. All runs require video proof and pass moderation before appearing on the board. Every figure on this page comes from speedrun.com with a visible verification date.
        </p>
        <p>
          Community discussion and route development happen at <a href="https://www.reddit.com/r/SilksongSpeedrun/" target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">r/SilksongSpeedrun</a>. New to speedrunning? The <a href="/speedruns/what-is-speedrunning/" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">speedrunning explainer</a> on this site covers timing methods, category terminology, and how leaderboards work.
        </p>
      </section>

      <!-- Video embed facade -->
      <section aria-labelledby="watch">
        <h2 id="watch" class="text-2xl font-bold text-white mb-4">Watch the Any% world record run</h2>
        <p class="text-gray-400 mb-4 text-sm">
          pyuk's {headline.time} Any% run — set {new Date(headline.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}. Exploit-volatile; see caveat above.
        </p>

        {videoId ? (
          <div class="relative w-full bg-gray-900 rounded-xl overflow-hidden border border-gray-800" style="aspect-ratio: 16/9;">
            <button
              id="video-play"
              class="absolute inset-0 w-full h-full flex flex-col items-center justify-center cursor-pointer group"
              aria-label="Watch on YouTube"
              data-videoid={videoId}
            >
              <img
                src={`https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`}
                alt="Thumbnail for pyuk's Hollow Knight: Silksong Any% world record run"
                class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-70 transition-opacity"
                loading="lazy"
                width="1280"
                height="720"
              />
              <div class="relative z-10 w-16 h-16 rounded-full bg-red-600 hover:bg-red-500 flex items-center justify-center transition-colors shadow-lg">
                <span class="text-white text-2xl pl-1" aria-hidden="true">▶</span>
              </div>
              <span class="relative z-10 text-white text-sm font-medium mt-3 bg-black/60 px-3 py-1 rounded">Watch on YouTube</span>
            </button>
            <iframe id="video-frame" class="hidden w-full h-full" title="Hollow Knight: Silksong Any% world record run" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        ) : (
          <div class="w-full bg-gray-900 border border-gray-800 rounded-xl flex items-center justify-center" style="aspect-ratio: 16/9; max-height: 360px;">
            <div class="text-center px-8">
              <div class="text-gray-600 text-4xl mb-3">▶</div>
              <p class="text-gray-400 text-sm">Video pending — check speedrun.com/silksong for the current verified run.</p>
              <a href="https://www.speedrun.com/silksong" target="_blank" rel="noopener" class="inline-block mt-3 text-indigo-400 underline underline-offset-2 hover:text-indigo-300 text-sm">View leaderboard on speedrun.com ↗</a>
            </div>
          </div>
        )}
      </section>

      <!-- PAA section -->
      <section aria-labelledby="paa">
        <h2 id="paa" class="text-2xl font-bold text-white mb-6">People also ask</h2>
        <div class="space-y-6">
          {faqQA.map(({ q, a }) => (
            <div class="border border-gray-800 rounded-xl p-5">
              <h3 class="text-base font-semibold text-white mb-2">{q}</h3>
              <p class="text-gray-400 text-sm leading-relaxed">{a}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Internal links / next steps -->
      <section aria-labelledby="next" class="border-t border-gray-800 pt-10">
        <h2 id="next" class="text-xl font-bold text-white mb-4">Time your own Silksong runs</h2>
        <p class="mb-4">
          If tracking the world record has you thinking about running Silksong yourself, the first thing you need is a split timer. The
          <a href="/speedrun-timer/" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">free speedrun timer on this site</a> handles named splits, PB comparison, hotkeys (Space to split, Enter to start/stop), and clipboard export for sharing. No account, no install, works offline.
        </p>
        <p class="text-sm text-gray-400">
          More WR trackers: <a href="/speedruns/minecraft-speedrun-world-record/" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">Minecraft speedrun WR</a> (Any% RSG Java 1.16.1 — a larger established community, deeper category structure than Silksong). Super Mario 64 categories coming.
          See the <a href="/speedruns/" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">speedruns hub</a> for all tracked pages.
        </p>
      </section>

    </div>
  </div>
</Base>

{videoId && (
  <script>
  const btn = document.getElementById('video-play');
  const frame = document.getElementById('video-frame') as HTMLIFrameElement;
  if (btn && frame) {
    btn.addEventListener('click', () => {
      const vid = btn.getAttribute('data-videoid');
      frame.src = `https://www.youtube.com/embed/${vid}?autoplay=1`;
      frame.classList.remove('hidden');
      btn.style.display = 'none';
    });
  }
  </script>
)}
