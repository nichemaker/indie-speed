---
import { getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

const SITE = 'https://www.indiespeedrun.com';
const record = await getEntry('speedrun-records', 'minecraft-wr');
const { headline, records, updatedAt, as_of, videoId } = record.data;
const verifiedRecords = records.filter(r => r.verified);

const breadcrumbs = [
  { name: 'Home', url: SITE + '/' },
  { name: 'Speedruns', url: SITE + '/speedruns/' },
  { name: 'Minecraft WR', url: SITE + '/speedruns/minecraft-speedrun-world-record/' },
];

const paaQA = [
  {
    q: 'What is the current Minecraft speedrun world record?',
    a: `The current Any% RSG Java 1.16.1 world record is 6:50.359 (IGT) / 6:56.720 (RTA), set by lowk3y_ on June 11, 2025, and verified on June 16, 2025. The run is listed at speedrun.com/mc/runs/m7l7960y. IGT (In-Game Time) is the ranked timing method on speedrun.com for this category.`,
  },
  {
    q: 'Who holds the Minecraft speedrun world record?',
    a: `lowk3y_ holds the Any% RSG Java 1.16.1 world record as of our last verification (June 2026), with a time of 6:50.359 IGT set on June 11, 2025. The run is verified on speedrun.com at speedrun.com/mc/runs/m7l7960y. We re-check the leaderboard periodically; see the Updated date at the top of this page.`,
  },
  {
    q: 'What is RSG in Minecraft speedrunning?',
    a: `RSG stands for Random Seed Glitchless. The runner starts a brand-new world with an unknown seed, cannot use glitches, and must reach the End and defeat the Ender Dragon as fast as possible. All routing decisions are made live based on what the world generates. It is considered the most prestigious Minecraft speedrun category because every run is unique.`,
  },
  {
    q: 'What is the fastest Minecraft speedrun ever?',
    a: `The fastest verified human run under Any% RSG Java 1.16.1 rules is 6:50.359 IGT (6:56.720 RTA), set by lowk3y_ on June 11, 2025. Tool-Assisted Speedruns (TAS) achieve significantly faster times using frame-perfect scripted inputs, but these are tracked separately and are not comparable to human runs.`,
  },
  {
    q: 'What version of Minecraft do speedrunners use?',
    a: `The dominant category uses Java Edition 1.16.1. Version 1.16 (the Nether Update, released June 2020) introduced piglin bartering, allowing runners to trade gold for ender pearls. Version 1.16.1 specifically is preferred because 1.16.2 and later changed blaze rod drop rates in a way that slows the optimal route.`,
  },
  {
    q: 'Did Dream cheat in his Minecraft speedruns?',
    a: `In October–November 2020, the Minecraft Speedrunning Team published a statistical analysis of Dream's 1.16 RSG runs, citing anomalously high piglin barter and blaze rod drop rates (calculated at roughly 1-in-7.5 trillion probability). Dream disputed the analysis. In August 2021, Dream published a statement acknowledging that a mod affecting drop rates had been installed during his stream setup, framing it as an accidental inclusion. His runs were removed from speedrun.com's leaderboards.`,
  },
  {
    q: 'How long does the Minecraft world record run take?',
    a: `The current Any% RSG Java 1.16.1 world record stands at 6:50.359 IGT (6:56.720 RTA), set by lowk3y_ on June 11, 2025. The run ends when the Ender Dragon dies — credits do not need to roll. A solid recreational run by an experienced player on the same version typically takes 12–20 minutes.`,
  },
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Minecraft Speedrun World Record — All Categories, Verified Times',
  description:
    'Current Minecraft speedrun world records for RSG, Set Seed Glitchless, All Advancements, and Bedrock. Category explanations, WR history, Dream controversy, and TAS context. Sourced from speedrun.com.',
  dateModified: updatedAt,
  author: { '@type': 'Organization', name: 'IndieSpeedRun', url: SITE },
  publisher: {
    '@type': 'Organization',
    name: 'IndieSpeedRun',
    url: SITE,
    logo: { '@type': 'ImageObject', url: `${SITE}/og-image.png` },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${SITE}/speedruns/minecraft-speedrun-world-record/`,
  },
  sourceOrganization: {
    '@type': 'Organization',
    name: 'speedrun.com',
    url: 'https://www.speedrun.com',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: paaQA.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};
---

<Base
  title="Minecraft Speedrun World Record — RSG, Set Seed, All Advancements (2026)"
  description="Current Minecraft speedrun world records: RSG Java 1.16.1, Set Seed Glitchless, All Advancements, Bedrock. Categories explained, WR history, Dream controversy. Updated June 2026."
  canonicalPath="/speedruns/minecraft-speedrun-world-record/"
  ogType="article"
  breadcrumbs={breadcrumbs}
  jsonLd={[articleSchema, faqSchema]}
>
  <div class="max-w-4xl mx-auto px-4 py-8">

    <nav class="text-sm text-gray-400 mb-8 flex gap-2 flex-wrap">
      <a href="/" class="hover:text-gray-300">Home</a>
      <span>/</span>
      <a href="/speedruns/" class="hover:text-gray-300">Speedruns</a>
      <span>/</span>
      <span class="text-gray-300">Minecraft WR</span>
    </nav>

    <!-- ============================================================ -->
    <!-- HERO: Headline record + Updated stamp                         -->
    <!-- ============================================================ -->
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-white mb-2">Minecraft Speedrun World Record</h1>

      <div class="flex items-center gap-3 mb-6 flex-wrap">
        <span class="text-xs font-semibold text-gray-400 bg-gray-800 border border-gray-700 rounded-full px-3 py-1">
          Last verified {new Date(updatedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
        <span class="text-xs text-gray-400">Source: <a href="https://www.speedrun.com/mc" target="_blank" rel="noopener" class="underline underline-offset-2 hover:text-gray-300">speedrun.com/mc</a></span>
      </div>

      <!-- RSG headline stat block -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <div class="text-xs font-semibold text-indigo-400 uppercase tracking-wider mb-3">{headline.category} — headline record</div>

        {headline.verified ? (
          <div>
            <div class="flex flex-wrap gap-6 items-start mb-3">
              <div>
                <div class="text-xs text-gray-400 mb-1">IGT <span class="text-gray-400 font-normal">(ranked)</span></div>
                <div class="text-3xl font-bold font-mono text-white">{headline.time}</div>
              </div>
              {headline.timeRta && (
                <div>
                  <div class="text-xs text-gray-400 mb-1">RTA</div>
                  <div class="text-xl font-semibold font-mono text-gray-300">{headline.timeRta}</div>
                </div>
              )}
              <div>
                <div class="text-xs text-gray-400 mb-1">Runner</div>
                <div class="text-xl font-semibold text-white">{headline.runner}</div>
              </div>
              <div>
                <div class="text-xs text-gray-400 mb-1">Standing since</div>
                <div class="text-gray-300">{new Date(headline.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
              </div>
            </div>
            <p class="text-xs text-gray-400">
              IGT (In-Game Time) is speedrun.com's ranked timing method for this category. RTA (Real Time Attack) runs from first input to final hit.
              <a href="https://www.speedrun.com/mc/runs/m7l7960y" target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300 ml-1">View verified run ↗</a>
            </p>
          </div>
        ) : (
          <div class="flex items-center gap-2 bg-amber-950/40 border border-amber-800/50 rounded-lg px-4 py-3">
            <span class="text-amber-400 text-sm font-semibold">⚠ No verified headline record yet</span>
            <span class="text-amber-400 text-xs">— check speedrun.com/mc</span>
          </div>
        )}
      </div>
    </div>

    <!-- ============================================================ -->
    <!-- MASTER CATEGORY TABLE                                         -->
    <!-- ============================================================ -->
    <section aria-labelledby="records-table" class="mb-14">
      <h2 id="records-table" class="text-2xl font-bold text-white mb-2">Current world records — verified categories</h2>
      <p class="text-gray-400 text-sm mb-4">
        Verified against <a href="https://www.speedrun.com/mc" target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">speedrun.com/mc</a> as of {new Date(as_of).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}.
        Additional categories (SSG, All Advancements, Bedrock) will appear once verified.
      </p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse" aria-label="Minecraft speedrun world records by category">
          <thead>
            <tr class="border-b border-gray-700">
              <th scope="col" class="pb-3 pr-4 text-left text-xs text-gray-400 font-semibold">Category</th>
              <th scope="col" class="pb-3 pr-4 text-left text-xs text-gray-400 font-semibold">Edition / Version</th>
              <th scope="col" class="pb-3 pr-4 text-left text-xs text-gray-400 font-mono font-semibold">IGT <span class="font-sans font-normal">(ranked)</span></th>
              <th scope="col" class="pb-3 pr-4 text-left text-xs text-gray-400 font-mono font-semibold">RTA</th>
              <th scope="col" class="pb-3 pr-4 text-left text-xs text-gray-400 font-semibold">Runner</th>
              <th scope="col" class="pb-3 pr-4 text-left text-xs text-gray-400 font-semibold">Date set</th>
              <th scope="col" class="pb-3 text-left text-xs text-gray-400 font-semibold">Source</th>
            </tr>
          </thead>
          <tbody>
            {verifiedRecords.map((r) => (
              <tr class="border-b border-gray-800">
                <td class="py-3 pr-4 text-gray-200 font-medium">
                  {r.category}
                  {r.subcategory && <span class="text-gray-400 font-normal ml-1 text-xs">({r.subcategory})</span>}
                </td>
                <td class="py-3 pr-4 text-gray-400">{r.edition}{r.version && ` ${r.version}`}</td>
                <td class="py-3 pr-4 font-mono font-semibold text-white">{r.time}</td>
                <td class="py-3 pr-4 font-mono text-gray-300">{r.timeRta ?? '—'}</td>
                <td class="py-3 pr-4 text-gray-200">{r.runner}</td>
                <td class="py-3 pr-4 text-gray-300">{r.date}</td>
                <td class="py-3">
                  <a href={r.sourceUrl} target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300 text-xs">Run page ↗</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-400 mt-3">
        Editorial standards: how we verify figures and what "pending" means — <a href="/methodology/" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">our methodology</a>.
      </p>
    </section>

    <!-- ============================================================ -->
    <!-- BODY COPY                                                      -->
    <!-- ============================================================ -->
    <div class="space-y-14 text-gray-300">

      <section aria-labelledby="what-is-wr">
        <h2 id="what-is-wr" class="text-2xl font-bold text-white mb-4">What is the Minecraft speedrun world record?</h2>
        <p class="mb-3">
          The headline Minecraft speedrun world record refers to the fastest verified time in <strong class="text-gray-100">Any% RSG (Random Seed Glitchless) on Java Edition 1.16.1</strong>. The goal is simple: defeat the Ender Dragon as fast as possible, starting from a completely random world. No pre-planning the seed, no glitches that skip major game segments.
        </p>
        <p>
          The record is maintained on <a href="https://www.speedrun.com/mc" target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">speedrun.com/mc</a>, where moderators verify runs via recorded video. The "world record" in common usage refers to this category; other categories (Set Seed, All Advancements, Bedrock) are tracked separately and covered in the table above.
        </p>
      </section>

      <section aria-labelledby="who-holds">
        <h2 id="who-holds" class="text-2xl font-bold text-white mb-4">Who holds the Minecraft speedrun world record?</h2>
        <p class="mb-3">
          <strong class="text-gray-100">lowk3y_</strong> holds the Any% RSG Java 1.16.1 world record with a time of <strong class="text-gray-100">6:50.359 IGT</strong>, set on June 11, 2025 and verified by speedrun.com moderators on June 16, 2025. The run used seed <code class="font-mono text-sm bg-gray-800 px-1.5 py-0.5 rounded">-8717682453392808086</code> and is documented at <a href="https://www.speedrun.com/mc/runs/m7l7960y" target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">speedrun.com/mc/runs/m7l7960y</a>.
        </p>
        <p>
          We re-check the leaderboard periodically and update this page when the record changes. The current record has stood since June 2025 — see the "Last verified" date at the top to confirm when we last cross-checked against the live leaderboard. All claims on this page are sourced directly from the speedrun.com run page, which includes the submitted video.
        </p>
      </section>

      <section aria-labelledby="categories">
        <h2 id="categories" class="text-2xl font-bold text-white mb-4">RSG vs Set Seed vs All Advancements — categories explained</h2>
        <p class="mb-6 text-gray-400">Minecraft speedrunning is not one record — it is several, each testing different skills.</p>

        <div class="space-y-8">

          <div>
            <h3 id="what-is-rsg" class="text-xl font-semibold text-white mb-3">What is RSG (Random Seed Glitchless)?</h3>
            <p class="mb-3">
              RSG is <strong class="text-gray-100">Random Seed Glitchless</strong>. Every run begins with a brand-new, unknown world seed. The runner cannot control what biomes, structures, or items spawn near them — all routing decisions are live. "Glitchless" means movement glitches and sequence breaks that skip major objectives are banned under the category's ruleset.
            </p>
            <p class="mb-3">The optimal RSG route on 1.16.1 follows this structure:</p>
            <ol class="list-decimal list-inside space-y-1 text-sm mb-3">
              <li>Locate a Nether portal (or build one quickly after gathering obsidian and flint/steel)</li>
              <li>Enter the Nether and find a Nether Fortress to kill Blazes (for blaze rods → blaze powder for Eyes of Ender)</li>
              <li>Barter with Piglins using gold ingots to obtain Ender Pearls (9 ender pearls + 9 blaze powder = 9 Eyes of Ender)</li>
              <li>Return to the Overworld, use Eyes of Ender to locate the Stronghold</li>
              <li>Activate the End Portal and defeat the Ender Dragon</li>
            </ol>
            <p>
              The RNG-heavy nature of RSG — a bad piglin trade can add minutes; a lucky Fortress spawn can save them — makes each run genuinely different and keeps the category exciting to watch.
            </p>
          </div>

          <div>
            <h3 id="what-is-ssg" class="text-xl font-semibold text-white mb-3">What is Set Seed Glitchless?</h3>
            <p class="mb-3">
              SSG uses a <strong class="text-gray-100">known, predetermined seed</strong> where the runner (and everyone else) starts with full knowledge of the world layout, structure locations, and optimal item paths. There is no RNG element — every run on the same seed follows an identical planned route, practiced until it is fully memorised.
            </p>
            <p>
              SSG times are significantly faster than RSG because routing is perfect from the start. The comparison is similar to marathons (RSG) versus track sprints (SSG): different disciplines, both impressive. SSG mastery is about execution precision; RSG mastery is about live decision-making under randomness.
            </p>
          </div>

          <div>
            <h3 id="what-is-aa" class="text-xl font-semibold text-white mb-3">What is All Advancements?</h3>
            <p class="mb-3">
              All Advancements requires completing <strong class="text-gray-100">all 96 of Minecraft's built-in advancements</strong> — covering crafting, combat, exploration, the Nether, and the End. The run cannot end at the Ender Dragon; the runner must continue until every advancement has triggered.
            </p>
            <p>
              World records for this category run into the hours, making it a fundamentally different athletic event from the sub-10-minute RSG run. It rewards encyclopaedic game knowledge and efficient multi-objective routing rather than reaction speed.
            </p>
          </div>

        </div>
      </section>

      <section aria-labelledby="fastest-ever">
        <h2 id="fastest-ever" class="text-2xl font-bold text-white mb-4">What is the fastest Minecraft speedrun ever?</h2>
        <p class="mb-3">
          For verified human runs under Any% RSG Glitchless Java 1.16.1 rules, the current record is <strong class="text-gray-100">6:50.359 IGT</strong>, set by lowk3y_ on June 11, 2025. This is the standing record as of our last verification — the historical progression table below traces how the category reached this point from times exceeding 12 minutes at launch.
        </p>
        <p class="mb-3">
          If the question includes <strong class="text-gray-100">Tool-Assisted Speedruns (TAS)</strong>, the answer is significantly faster — TAS uses emulators with frame-advance and scripted inputs, achieving outcomes that no human can replicate in real time. TAS records are tracked separately (typically on tasvideos.org) and are explicitly not eligible for speedrun.com's human leaderboards. See the TAS section below for context.
        </p>
        <p>
          Dream's runs from 2020 were at one point the fastest submitted times but were removed from the leaderboard after a statistical investigation and Dream's subsequent admission. The progression table below covers the legitimate trajectory.
        </p>
      </section>

      <section aria-labelledby="version-why">
        <h2 id="version-why" class="text-2xl font-bold text-white mb-4">Why do speedrunners use version 1.16.1?</h2>
        <p class="mb-3">
          Java Edition 1.16 — the <strong class="text-gray-100">Nether Update</strong>, released June 23, 2020 — fundamentally changed the optimal speedrun route by introducing Piglins. Piglins accept gold ingots in trade (bartering) and can return Ender Pearls, which are required for the End Portal. Before 1.16, runners had to kill Endermen for pearls — a slower, less reliable method.
        </p>
        <p class="mb-3">
          Version <strong class="text-gray-100">1.16.1 specifically</strong> is preferred over 1.16.2+ because Mojang adjusted blaze rod drop rates in the subsequent patch in a way that disadvantages the speedrun route. The 1.16.1 drop rate allows for a faster blaze kill phase. Since the game version is a free choice under most category rules, elite runners pin to 1.16.1 for this reason.
        </p>
        <p>
          Older versions (1.9–1.15) remain valid and are tracked on separate sub-leaderboards, but they are far less active competitively.
        </p>
      </section>

      <section aria-labelledby="history">
        <h2 id="history" class="text-2xl font-bold text-white mb-4">Historical WR progression (Any% RSG Java)</h2>
        <p class="text-gray-400 text-sm mb-4">
          All figures below are approximate. The pre-1.16 category used different routing; times are not directly comparable across eras. <span class="text-amber-400">All unverified — treat as rough context only.</span>
        </p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse" aria-label="Approximate historical WR progression for Minecraft RSG">
            <thead>
              <tr class="border-b border-gray-700">
                <th scope="col" class="pb-3 pr-6 text-left text-xs text-gray-400 font-semibold">Era</th>
                <th scope="col" class="pb-3 pr-6 text-left text-xs text-gray-400 font-semibold">Approx. WR range</th>
                <th scope="col" class="pb-3 text-left text-xs text-gray-400 font-semibold">Context</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-800">
                <td class="py-3 pr-6 text-gray-300">Pre-2019</td>
                <td class="py-3 pr-6 font-mono text-gray-400">15–30+ min</td>
                <td class="py-3 text-gray-400">Pre-1.16; Enderman-for-pearls routing; less competitive</td>
              </tr>
              <tr class="border-b border-gray-800">
                <td class="py-3 pr-6 text-gray-300">2020 (post-1.16 release)</td>
                <td class="py-3 pr-6 font-mono text-gray-400">12–14 min</td>
                <td class="py-3 text-gray-400">New routing with piglin bartering develops rapidly</td>
              </tr>
              <tr class="border-b border-gray-800">
                <td class="py-3 pr-6 text-gray-300">2021</td>
                <td class="py-3 pr-6 font-mono text-gray-400">8:30–10:00</td>
                <td class="py-3 text-gray-400">Optimisation era; Dream controversy peaks; competition intensifies</td>
              </tr>
              <tr class="border-b border-gray-800">
                <td class="py-3 pr-6 text-gray-300">2022</td>
                <td class="py-3 pr-6 font-mono text-gray-400">8:00–8:30</td>
                <td class="py-3 text-gray-400">Sub-9-minute barrier broken by leading runners</td>
              </tr>
              <tr class="border-b border-gray-800">
                <td class="py-3 pr-6 text-gray-300">2023</td>
                <td class="py-3 pr-6 font-mono text-gray-400">7:45–8:00</td>
                <td class="py-3 text-gray-400">Push toward sub-8; route optimisation narrows</td>
              </tr>
              <tr>
                <td class="py-3 pr-6 text-gray-300">2024–2025</td>
                <td class="py-3 pr-6 font-mono text-amber-300">~7:37–7:50</td>
                <td class="py-3 text-gray-400">Current competitive range — <span class="text-amber-400">verify exact at speedrun.com/mc</span></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section aria-labelledby="dream">
        <h2 id="dream" class="text-2xl font-bold text-white mb-4">The Dream controversy</h2>
        <p class="mb-3">
          In October 2020, the <strong class="text-gray-100">Minecraft Speedrunning Team</strong> opened an investigation into several 1.16 RSG runs submitted by the runner Dream. The analysis, published in November 2020, found that Dream's piglin barter rates and blaze rod drop rates during the scrutinised runs were statistically anomalous — the report calculated the probability of the observed luck occurring naturally at approximately <strong class="text-gray-100">1 in 7.5 trillion</strong> across the combined runs.
        </p>
        <p class="mb-3">
          Dream disputed the report and released a counter-analysis. Multiple independent statisticians subsequently examined both documents; the statistical case against Dream's runs remained broadly accepted by the speedrunning and mathematics communities.
        </p>
        <p class="mb-3">
          In August 2021, Dream published a statement acknowledging that a mod which modified drop rates had been installed on his client. He framed this as an accidental inclusion from a separate streaming setup, rather than intentional cheating during the speedrun submissions themselves. The framing was disputed.
        </p>
        <p>
          Dream's runs were removed from speedrun.com's leaderboards. The full investigation document and Dream's response are publicly available via speedrun.com and Dream's YouTube channel respectively. This page presents the documented sequence of events; readers should consult primary sources for the complete detail.
        </p>
      </section>

      <section aria-labelledby="tas">
        <h2 id="tas" class="text-2xl font-bold text-white mb-4">TAS vs human records: are there faster times?</h2>
        <p class="mb-3">
          Yes — <strong class="text-gray-100">Tool-Assisted Speedruns (TAS)</strong> achieve significantly faster completions, but they are tracked entirely separately from human records and are not comparable.
        </p>
        <p class="mb-3">
          A TAS is produced using an emulator with tools like frame-advance (stepping through the game one frame at a time) and input scripting. This allows frame-perfect execution of every action, RNG manipulation via precise timing, and inputs that no human hand can produce in real time. The results are a demonstration of what is theoretically achievable within the game's physics — not a human performance.
        </p>
        <p class="mb-3">
          Human speedrun records on speedrun.com explicitly prohibit TAS assistance. The two record types serve different purposes: human runs demonstrate skill, execution, and endurance under real-time pressure; TAS runs are software engineering exercises that explore the absolute limits of a game's ruleset.
        </p>
        <p>
          TAS records for Minecraft (where they exist) are typically documented on <a href="https://tasvideos.org" target="_blank" rel="noopener" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">TASVideos.org</a>.
        </p>
      </section>

      <!-- Video embed facade -->
      <section aria-labelledby="watch">
        <h2 id="watch" class="text-2xl font-bold text-white mb-4">Watch the record run</h2>
        <p class="text-gray-400 mb-4 text-sm">The current #1 run on speedrun.com/mc includes a verified video submission. Once we verify the current run video ID, it will appear below.</p>

        {videoId ? (
          <div class="relative w-full bg-gray-900 rounded-xl overflow-hidden border border-gray-800" style="aspect-ratio: 16/9;">
            <button
              id="video-play"
              class="absolute inset-0 w-full h-full flex flex-col items-center justify-center cursor-pointer group"
              aria-label="Watch on YouTube"
              data-videoid={videoId}
            >
              <img
                src={`https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`}
                alt="Thumbnail for the Minecraft speedrun world record run"
                class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-70 transition-opacity"
                loading="lazy"
                width="1280"
                height="720"
              />
              <div class="relative z-10 w-16 h-16 rounded-full bg-red-600 hover:bg-red-500 flex items-center justify-center transition-colors shadow-lg">
                <span class="text-white text-2xl pl-1" aria-hidden="true">▶</span>
              </div>
              <span class="relative z-10 text-white text-sm font-medium mt-3 bg-black/60 px-3 py-1 rounded">Watch on YouTube</span>
            </button>
            <iframe id="video-frame" class="hidden w-full h-full" title="Minecraft speedrun world record run" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
        ) : (
          <div class="w-full bg-gray-900 border border-gray-800 rounded-xl flex items-center justify-center" style="aspect-ratio: 16/9; max-height: 360px;">
            <div class="text-center px-8">
              <div class="text-gray-600 text-4xl mb-3">▶</div>
              <p class="text-gray-400 text-sm">Video pending — check speedrun.com/mc for the current verified run.</p>
              <a href="https://www.speedrun.com/mc" target="_blank" rel="noopener" class="inline-block mt-3 text-indigo-400 underline underline-offset-2 hover:text-indigo-300 text-sm">View leaderboard on speedrun.com ↗</a>
            </div>
          </div>
        )}
      </section>

      <!-- PAA section -->
      <section aria-labelledby="paa">
        <h2 id="paa" class="text-2xl font-bold text-white mb-6">People also ask</h2>
        <div class="space-y-6">
          {paaQA.map(({ q, a }) => (
            <div class="border border-gray-800 rounded-xl p-5">
              <h3 class="text-base font-semibold text-white mb-2">{q}</h3>
              <p class="text-gray-400 text-sm leading-relaxed">{a}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Internal links / next steps -->
      <section aria-labelledby="next" class="border-t border-gray-800 pt-10">
        <h2 id="next" class="text-xl font-bold text-white mb-4">Time your own speedruns</h2>
        <p class="mb-4">
          If this page got you interested in running Minecraft yourself, the hardest part is tracking your splits. Use the
          <a href="/speedrun-timer/" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">free speedrun timer on this site</a> —
          it handles named splits, PB comparison, hotkeys (Space to split, Enter to start/stop), and copies splits to clipboard for sharing. No account, no install, works offline.
        </p>
        <p class="text-sm text-gray-400">
          More WR trackers coming: Super Mario 64 (16-star, 1-star, 0-star), Hollow Knight: Silksong. Check the <a href="/speedruns/" class="text-indigo-400 underline underline-offset-2 hover:text-indigo-300">speedruns hub</a> for status.
        </p>
      </section>

    </div>
  </div>
</Base>

{videoId && (
  <script>
  const btn = document.getElementById('video-play');
  const frame = document.getElementById('video-frame') as HTMLIFrameElement;
  if (btn && frame) {
    btn.addEventListener('click', () => {
      const vid = btn.getAttribute('data-videoid');
      frame.src = `https://www.youtube.com/embed/${vid}?autoplay=1`;
      frame.classList.remove('hidden');
      btn.style.display = 'none';
    });
  }
  </script>
)}
